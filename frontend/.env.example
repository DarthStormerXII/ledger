# Ledger frontend — public environment
# These vars are exposed to the browser. Copy to .env.local and tweak only if
# you're pointing at a different testnet stack than the live one.

# === 0G Galileo (chainId 16602) — primary L2 ===
NEXT_PUBLIC_GALILEO_RPC=https://evmrpc-testnet.0g.ai

# === Sepolia L1 — for ENS Universal Resolver ===
NEXT_PUBLIC_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# === Base Sepolia — for ERC-8004 reputation registry ===
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# === Live deployed Ledger contracts ===
NEXT_PUBLIC_WORKER_INFT_ADDRESS=0xd4d74E089DD9A09FF768be95d732081bd542E498
NEXT_PUBLIC_LEDGER_ESCROW_ADDRESS=0x83dF0Ed0b4f3D1D057cB56494b8c7eE417265489
NEXT_PUBLIC_LEDGER_IDENTITY_REGISTRY_ADDRESS=0x9581490E530Da772Af332EBCe3f35D27d5e8377F
NEXT_PUBLIC_MOCK_TEE_ORACLE_ADDRESS=0x306919805Eed1aD4772d92e18d00A1c132b07C19
NEXT_PUBLIC_ERC8004_REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713

# === ENS resolver ===
NEXT_PUBLIC_LEDGER_ENS_PARENT=ledger.eth
NEXT_PUBLIC_LEDGER_ENS_RESOLVER_CONTRACT=0xd94cC429058E5495a57953c7896661542648E1B3
# Provide the ngrok URL emitted by the resolver builder. Update when it changes.
NEXT_PUBLIC_LEDGER_ENS_GATEWAY_URL=https://resolver.fierypools.fun/{sender}/{data}
